<!-- Pick-and-place scene: xArm6 + table + cube object + visual target. -->
<mujoco model="xarm6_pick_place">
  <include file="xarm6/xarm6.xml"/>

  <statistic center="0.3 0 0.4" extent="1.2"/>
  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0"
             width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
             rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8"
             width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true"
              texrepeat="5 5" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" diffuse="0.8 0.8 0.8"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <body name="table" pos="0.5 0 0.2">
      <geom name="table_geom" type="box" size="0.3 0.4 0.2"
            rgba="0.6 0.45 0.3 1" contype="1" conaffinity="1"
            friction="1.0 0.05 0.001"/>
    </body>

    <!-- Cube to pick up -->
    <body name="cube" pos="0.5 0.0 0.43">
      <freejoint name="cube_free"/>
      <geom name="cube_geom" type="box" size="0.022 0.022 0.022"
            rgba="0.9 0.1 0.1 1" mass="0.05"
            friction="2.0 0.05 0.001"
            solref="0.005 1" solimp="0.95 0.99 0.001" condim="4"/>
    </body>

    <!-- Target site (visual only, mocap) -->
    <body name="target" mocap="true" pos="0.5 0.2 0.5">
      <geom name="target_geom" type="sphere" size="0.025"
            rgba="0 1 0 0.5" contype="0" conaffinity="0"/>
    </body>
  </worldbody>
</mujoco>
