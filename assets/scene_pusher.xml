<!-- Pusher scene: xArm6 + table + pushable cylinder + visual goal marker. -->
<mujoco model="xarm6_pusher">
  <include file="xarm6/xarm6.xml"/>

  <statistic center="0.3 0 0.4" extent="1.2"/>
  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="90" elevation="-75"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0"
             width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge"
             rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8"
             width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true"
              texrepeat="5 5" reflectance="0.2"/>
  </asset>

  <worldbody>
    <camera name="topdown" pos="0.4 0 1.2" euler="0 0 90" fovy="60"/>
    <light pos="0 0 1.5" dir="0 0 -1" diffuse="0.8 0.8 0.8"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- Table -->
    <body name="table" pos="0.5 0 0.2">
      <geom type="box" size="0.3 0.4 0.2" rgba="0.6 0.45 0.3 1" contype="1" conaffinity="1"/>
    </body>

    <!-- Pushable cylinder object (free joint so it slides on the table) -->
    <body name="object" pos="0.35 0.0 0.42">
      <joint name="object_freejoint" type="free"/>
      <geom name="object_geom" type="cylinder" size="0.025 0.03"
            rgba="0.8 0.2 0.2 1" mass="0.1" contype="1" conaffinity="1"
            friction="0.8 0.005 0.0001"/>
    </body>

    <!-- Visual-only goal marker (no collision); position set via mocap -->
    <body name="goal" mocap="true" pos="0.45 0.15 0.421">
      <geom name="goal_geom" type="cylinder" size="0.025 0.002"
            rgba="0 0.8 0 0.5" contype="0" conaffinity="0"/>
    </body>
  </worldbody>
</mujoco>
